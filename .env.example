# Django Security Settings
# 生成新的secret key: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=your-secret-key-here

# Debug mode - set to False in production
DEBUG=True

# Host Settings - comma separated list
ALLOWED_HOSTS=localhost,127.0.0.1,your-domain.com
TRUSTED_PROXIES=127.0.0.1,172.17.0.1

# Database Settings
# Set DATABASE_TYPE to MYSQL to use MySQL, otherwise SQLite will be used
DATABASE_TYPE=SQLITE  # or MYSQL，本地开发用SQLITE
# MySQL Database Configuration (only used when DATABASE_TYPE=MYSQL)
DB_NAME=your_database_name
DB_USER=your_database_user
DB_PASSWORD=your_database_password
DB_HOST=127.0.0.1
DB_PORT=3306